# Copy this to .env and fill in your values
# NEVER commit .env to git

# Telegram
TELEGRAM_BOT_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# Intervals.icu
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=       # e.g. i12345 (find in your Intervals profile URL)

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=ai_coach_verify   # any string — must match when registering webhook

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=coach@yourdomain.com

# Postgres — Railway injects DATABASE_URL automatically
# For local dev, set it manually:
DATABASE_URL=postgresql://user:password@localhost:5432/aicoach

# Single-athlete setup: your Telegram user ID (find via @userinfobot on Telegram)
TELEGRAM_ATHLETE_ID=
